{
	"name": "@ryot/app-backend",
	"main": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./contract": "./src/contract.ts"
	},
	"scripts": {
		"test": "bun test",
		"dev": "bun run --watch src/index.ts",
		"db:generate": "bun --bun drizzle-kit generate",
		"check": "tsc && oxfmt . --write && oxlint . --type-aware --fix",
		"build": "bun build src/index.ts --outdir dist --target bun --sourcemap"
	},
	"dependencies": {
		"@effect/platform": "0.96.1",
		"@effect/platform-bun": "0.90.0",
		"better-auth": "1.6.15",
		"drizzle-orm": "0.45.2",
		"effect": "3.21.3",
		"pg": "8.21.0"
	},
	"devDependencies": {
		"@types/pg": "8.20.0",
		"bun-types": "1.3.14",
		"drizzle-kit": "0.31.10",
		"typescript": "6.0.3"
	}
}
