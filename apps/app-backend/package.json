{
	"name": "@ryot/app-backend",
	"main": "src/index.ts",
	"exports": {
		"./lib/*": {
			"types": "./src/lib/*.ts",
			"default": "./src/lib/*.ts"
		}
	},
	"scripts": {
		"test": "bun test",
		"dev": "bun run --watch src/index.ts",
		"db:generate": "bun --bun drizzle-kit generate",
		"check": "tsc && oxfmt . --write && oxlint . --type-aware --fix",
		"run-migration": "RUN_LEGACY_BOOTSTRAP_ONLY=true bun run src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun --sourcemap"
	},
	"dependencies": {
		"@better-auth/api-key": "1.6.13",
		"@better-auth/expo": "1.6.13",
		"@better-auth/redis-storage": "1.6.13",
		"@hono/node-server": "2.0.4",
		"@hono/zod-openapi": "1.4.0",
		"@ryot/ts-utils": "workspace:*",
		"@scalar/hono-api-reference": "0.10.19",
		"better-auth": "1.6.13",
		"bullmq": "5.77.6",
		"drizzle-orm": "0.45.2",
		"fast-xml-parser": "5.8.0",
		"fast-xml-validator": "1.1.0",
		"hono": "4.12.23",
		"ioredis": "5.11.0",
		"papaparse": "5.5.3",
		"pg": "8.21.0",
		"prom-client": "15.1.3",
		"ts-pattern": "5.9.0",
		"yauzl": "3.3.2",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@types/papaparse": "5.5.2",
		"@types/pg": "8.20.0",
		"@types/yauzl": "2.10.3",
		"@types/yazl": "3.3.1",
		"dotenv": "17.4.2",
		"drizzle-kit": "0.31.10",
		"openapi-typescript": "7.13.0",
		"typescript": "6.0.3",
		"yazl": "3.3.1"
	}
}
