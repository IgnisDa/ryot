{
	"name": "@ryot/app-backend",
	"main": "src/index.ts",
	"scripts": {
		"typecheck": "tsc",
		"test": "bun test --only-failures",
		"dev": "bun run --watch src/index.ts",
		"lint": "oxlint . && oxfmt --check .",
		"db:generate": "bun --bun drizzle-kit generate",
		"build": "bun build src/index.ts --outdir dist --target bun --sourcemap"
	},
	"dependencies": {
		"@better-auth/api-key": "1.6.5",
		"@better-auth/redis-storage": "1.6.5",
		"@hono/node-server": "1.19.14",
		"@hono/zod-openapi": "1.3.0",
		"@ryot/ts-utils": "workspace:*",
		"@scalar/hono-api-reference": "0.10.9",
		"better-auth": "1.6.5",
		"bullmq": "5.74.1",
		"drizzle-orm": "0.45.2",
		"hono": "4.12.14",
		"ioredis": "5.10.1",
		"pg": "8.20.0",
		"prom-client": "15.1.3",
		"ts-pattern": "5.9.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@types/pg": "8.20.0",
		"dotenv": "17.4.2",
		"drizzle-kit": "0.31.10",
		"openapi-typescript": "7.13.0",
		"typescript": "6.0.3"
