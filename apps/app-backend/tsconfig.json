{
	"compilerOptions": {
		"noEmit": true,
		"strict": true,
		"lib": ["ESNext"],
		"target": "ES2022",
		"module": "ESNext",
		"skipLibCheck": true,
		"types": ["bun-types"],
		"moduleResolution": "bundler",
		"paths": { "~/*": ["./src/*"] },
		"noUncheckedIndexedAccess": true,
		"plugins": [
			{
				"name": "@effect/language-service",
				"diagnosticSeverity": {
					"newPromise": "warning",
					"asyncFunction": "warning",
					"processEnvInEffect": "error",
					"nodeBuiltinImport": "warning",
					"globalFetchInEffect": "error",
					"globalDateInEffect": "warning",
					"globalTimersInEffect": "warning",
					"preferSchemaOverJson": "warning",
					"globalConsoleInEffect": "warning",
					"leakingRequirements": "off"
				}
			}
		]
	}
}
