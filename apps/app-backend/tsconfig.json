{
	"compilerOptions": {
		"baseUrl": ".",
		"noEmit": true,
		"strict": true,
		"jsx": "react-jsx",
		"target": "ES2022",
		"module": "ESNext",
		"skipLibCheck": true,
		"types": ["bun-types"],
		"moduleResolution": "bundler",
		"jsxImportSource": "hono/jsx",
		"paths": {
			"~/*": ["src/*"],
			"@ryot/ts-utils/dayjs": ["../../libs/ts-utils/src/dayjs.ts"]
		},
		"noUncheckedIndexedAccess": true
	}
}
