{
	"name": "@ryot/app-backend-reference",
	"main": "src/index.ts",
	"scripts": {
		"seed": "bun run seed-script.ts",
		"test": "bun --bun run vitest run",
		"dev": "bun run --watch src/index.ts",
		"db:generate": "bun --bun drizzle-kit generate",
		"check": "tsc && oxfmt . --write && oxlint . --type-aware --fix",
		"build": "bun build src/index.ts --outdir dist --target bun --sourcemap"
	},
	"dependencies": {
		"@better-auth/api-key": "1.6.15",
		"@better-auth/expo": "1.6.15",
		"@better-auth/redis-storage": "1.6.15",
		"@effect/cluster": "0.59.0",
		"@effect/experimental": "0.60.0",
		"@effect/opentelemetry": "0.63.0",
		"@effect/platform": "0.96.1",
		"@effect/platform-bun": "0.90.0",
		"@effect/sql-pg": "0.52.1",
		"@effect/workflow": "0.18.2",
		"@opentelemetry/api": "1.9.1",
		"@opentelemetry/exporter-metrics-otlp-http": "0.218.0",
		"@opentelemetry/exporter-trace-otlp-http": "0.218.0",
		"@opentelemetry/resources": "2.7.1",
		"@opentelemetry/sdk-logs": "0.218.0",
		"@opentelemetry/sdk-metrics": "2.7.1",
		"@opentelemetry/sdk-trace-node": "2.7.1",
		"better-auth": "1.6.15",
		"drizzle-orm": "0.45.2",
		"effect": "3.21.3",
		"ioredis": "5.11.1",
		"pg": "8.21.0"
	},
	"devDependencies": {
		"@effect/vitest": "0.29.0",
		"@types/pg": "8.20.0",
		"dotenv": "17.4.2",
		"drizzle-kit": "0.31.10",
		"typescript": "6.0.3",
		"vitest": "3.2.6"
	}
}
